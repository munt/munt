             <item>
              <widget class="QCheckBox" name="pinVolumeCheckBox">
               <property name="toolTip">
                <string>Enables pinned mode for the Master Volume control.
When it is ON, the Master Volume can only be set manually
and cannot be altered via the system SysEx messages.</string>
               </property>
               <property name="text">
                <string>Pin</string>
               </property>
              </widget>
             </item>
            </layout>
           </item>
           <item>
            <widget class="QSlider" name="masterVolumeSlider">
             <property name="sizePolicy">
              <sizepolicy hsizetype="Minimum" vsizetype="Fixed">
               <horstretch>0</horstretch>
               <verstretch>0</verstretch>
              </sizepolicy>
             </property>
             <property name="toolTip">
              <string>Master Volume control affects the level of each partial before mixing
(with a few exceptions on old-gen devices). It used to be a common
means to lower the Master Volume to avoid distortions in the mixer.
However, the levels of partials were only slightly affected on the
new-gen devices since they incorporated a voltage-controlled amplifier
as well. This control works the way it did on old-gen devices, and
the output signal level is controlled separately.</string>
             </property>
             <property name="maximum">
              <number>100</number>
             </property>
             <property name="value">
              <number>100</number>
             </property>
             <property name="orientation">
              <enum>Qt::Horizontal</enum>
             </property>
             <property name="tickPosition">
              <enum>QSlider::TicksAbove</enum>
             </property>
             <property name="tickInterval">
              <number>10</number>
             </property>
            </widget>
